generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specifications {
  productId   String?
  specName    String?
  description String?
  specId      Int     @id @default(autoincrement())
}

model admin {
  id       Int    @id @default(autoincrement())
  username String @unique @db.VarChar(50)
  password String @db.VarChar(255)
}

model categories {
  id         Int       @id
  name       String    @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model leads {
  id               Int       @id @default(autoincrement())
  name             String?   @db.VarChar(100)
  email            String?   @db.VarChar(100)
  phone            String?   @db.VarChar(20)
  message          String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  state            String?   @db.VarChar(100)
  machinery        String?   @db.VarChar(150)
  landing_page_url String?
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model price_update {
  title            String?
  cc               String?
  category         String?
  mrp              Decimal? @db.Decimal
  final_price      Decimal? @db.Decimal
  discount_percent Decimal? @db.Decimal
  amount_saved     Decimal? @db.Decimal

  @@ignore
}

model products {
  id              Int         @id @default(autoincrement())
  title           String?
  description     String?
  price           Decimal?    @db.Decimal(10, 2)
  mrp             Decimal?    @db.Decimal(10, 2)
  image           String?
  rating          Decimal?    @db.Decimal(3, 1)
  category_id     Int?
  created_at      String?
  category        String?
  images          String?
  features        String?
  cc              String?
  specifications  String?
  idealfor        String?
  discountpercent Int?
  amountsaved     Decimal?    @db.Decimal(10, 2)
  media1          String?
  media2          String?
  media3          String?
  media4          String?
  media5          String?
  updated_at      String?
  cartItems       CartItem[]
  orderItems      OrderItem[]
}

model Order {
  id                String      @id @default(uuid())
  userId            String
  totalAmount       Int
  status            String      @default("PENDING")
  createdAt         DateTime    @default(now())
  addressLine       String
  city              String
  fullName          String
  phone             String
  pincode           String
  state             String
  paymentStatus     String      @default("INITIATED")
  razorpayOrderId   String?
  razorpayPaymentId String?
  user              User        @relation(fields: [userId], references: [id])
  orderItems        OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId Int
  title     String
  price     Float
  quantity  Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
  product   products @relation(fields: [productId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  phone     String   @unique
  role      String   @default("user")
  createdAt DateTime @default(now())
  cart      Cart?
  orders    Order[]
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId Int
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id])
  product   products @relation(fields: [productId], references: [id])
}
